{
    "name": "waotomatis/sdk",
    "version": "0.4.0",
    "description": "Official PHP SDK for WAOtomatis — headless WhatsApp (WABA Cloud API).",
    "type": "library",
    "license": "MIT",
    "homepage": "https://waotomatis.com",
    "keywords": ["waotomatis", "whatsapp", "whatsapp-api", "waba", "sdk", "php"],
    "authors": [
        {
            "name": "WAOtomatis",
            "homepage": "https://waotomatis.com"
        }
    ],
    "support": {
        "issues": "https://github.com/waotomatis/sdk-php/issues",
        "source": "https://github.com/waotomatis/sdk-php",
        "docs": "https://docs.waotomatis.com"
    },
    "require": {
        "php": ">=8.1",
        "ext-json": "*"
    },
    "suggest": {
        "ext-curl": "Uses cURL for HTTP when available; falls back to the PHP stream wrapper otherwise."
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Waotomatis\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Waotomatis\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
